---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  buttonIcon: string;
  buttonTitle: string;
  buttonURL:string;
  buttonID: string;
  buttonCopyIcon: string;
}

const { buttonIcon, buttonTitle, buttonURL, buttonID, buttonCopyIcon } = Astro.props;
//
const iconsActions = import.meta.glob<{ default: ImageMetadata }>('/src/assets/icons/actions/*.{jpeg,jpg,png,gif,svg,avif}')
if (!iconsActions[buttonCopyIcon]) throw new Error(`"${buttonCopyIcon}" does not exist in glob."`);
//
const iconsBranding = import.meta.glob<{ default: ImageMetadata }>('/src/assets/icons/branding/*.{jpeg,jpg,png,gif,svg,avif}')
if (!iconsBranding[buttonIcon]) throw new Error(`"${buttonIcon}" does not exist in glob."`);
---

<button
  id={buttonID}
  class=""
>
  <Image src={iconsBranding[buttonIcon]()}
    alt={buttonTitle}
    class="  "
  />
  <span>
    {buttonTitle}
  </span>
    <Image src={iconsActions[buttonCopyIcon]()}
      alt=""
      class=""
    />
</button>

<script>
/*   document.getElementById({buttonID}).addEventListener("click", buttonURLClickHandler);
  function buttonURLClickHandler () {
    window.open({buttonURL}, '_blank');
  } */
</script>