---
import { isLocaleInList, supportedLanguages } from 'src/components/logic/get-locale';
//
async function loadLocalizedContent(userLocale:string) {
  let contentModule;
  if (isLocaleInList(userLocale, ['es-ES', 'es-419', 'es'])) {
    contentModule = await import('src/components/main-items/about/AcercaDe.mdx');
  } else if (isLocaleInList(userLocale, ['en-US', 'en-GB', 'en'])) {
    contentModule = await import('src/components/main-items/about/About.mdx');
  } else {
    contentModule = await import('src/components/main-items/about/AboutUnknownLocale.mdx');
  }
  return contentModule.default;
}
//
const { locale } = Astro.props;
const Content = await loadLocalizedContent(locale);
---
<Content />