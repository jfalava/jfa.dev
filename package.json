{
  "name": "@jfa.dev/monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "web/*",
      "function/*"
    ],
    "catalogs": {
      "backend": {
        "hono": "4.12.31"
      },
      "build": {
        "@vitejs/plugin-react": "6.0.4",
        "oxfmt": "0.56.0",
        "oxlint": "1.57.0",
        "oxlint-tsgolint": "7.0.2001",
        "typescript": "7.0.2",
        "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5",
        "vite-plus": "0.2.5",
        "vitest": "4.1.2",
        "wrangler": "4.113.0"
      },
      "cloudflare": {
        "@cloudflare/vite-plugin": "1.46.0",
        "@cloudflare/workers-types": "5.20260721.1"
      },
      "react-ui": {
        "@base-ui/react": "1.6.0",
        "lucide-react": "1.25.0",
        "react": "19.2.8",
        "react-dom": "19.2.8",
        "shadcn": "4.13.1"
      },
      "styling": {
        "@tailwindcss/vite": "4.3.3",
        "class-variance-authority": "0.7.1",
        "clsx": "2.1.1",
        "tailwind-merge": "3.6.0",
        "tailwindcss": "4.3.3",
        "tw-animate-css": "1.4.0"
      },
      "tanstack": {
        "@tanstack/react-router": "1.170.18",
        "@tanstack/react-router-ssr-query": "1.167.1",
        "@tanstack/react-start": "1.168.32",
        "@tanstack/router-plugin": "1.168.23"
      },
      "types": {
        "@types/bun": "1.3.14",
        "@types/node": "26.1.1",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3"
      }
    }
  },
  "type": "module",
  "scripts": {
    "check:catalog": "vp exec bun scripts/check-catalog-usage.ts",
    "check:global": "vp run --filter @jfa.dev/landing --filter @jfa.dev/redirects --filter @jfa.dev/og-img-gen check",
    "check:outdated": "vp exec bun scripts/check-outdated-catalog.ts",
    "format": "vp fmt",
    "format:global": "vp run --filter @jfa.dev/landing --filter @jfa.dev/redirects --filter @jfa.dev/og-img-gen format"
  },
  "dependencies": {
    "jsdom": "29.1.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/jsdom": "28.0.3",
    "@types/node": "26.1.1",
    "oxfmt": "0.58.0",
    "typescript": "7.0.2",
    "vite-plus": "0.2.4"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5"
  },
  "packageManager": "bun@1.3.14"
}
