{
  "name": "@jfa.dev/monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "check:catalog": "vp exec bun scripts/check-catalog-usage.ts",
    "check:global": "vp run --filter @jfa.dev/landing --filter @jfa.dev/redirects --filter @jfa.dev/og-img-gen check",
    "check:outdated": "vp exec bun scripts/check-outdated-catalog.ts",
    "format": "vp fmt",
    "format:global": "vp run --filter @jfa.dev/landing --filter @jfa.dev/redirects --filter @jfa.dev/og-img-gen format"
  },
  "dependencies": {
    "jsdom": "29.0.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/jsdom": "28.0.1",
    "@types/node": "25.5.0",
    "oxfmt": "0.42.0",
    "vite-plus": "0.1.13"
  },
  "packageManager": "pnpm@10.32.1"
}
