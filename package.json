        "wrangler": "4.97.0"
      },
      "cloudflare": {
        "@cloudflare/vite-plugin": "1.39.2",
        "@cloudflare/workers-types": "4.20260603.1"
      },
      "react-ui": {
        "@base-ui/react": "1.5.0",
        "lucide-react": "1.17.0",
