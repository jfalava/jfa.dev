{
  "name": "@jfa.dev/monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "web/*",
      "function/*"
    ],
    "catalogs": {
      "backend": {
        "hono": "4.12.29"
      },
      "build": {
        "@vitejs/plugin-react": "6.0.3",
        "oxfmt": "0.56.0",
        "oxlint": "1.57.0",
        "oxlint-tsgolint": "0.18.1",
        "typescript": "7.0.2",
        "vite": "8.1.4",
        "vite-plus": "0.2.4",
        "vitest": "4.1.2",
        "wrangler": "4.110.0"
      },
      "cloudflare": {
        "@cloudflare/vite-plugin": "1.44.0",
        "@cloudflare/workers-types": "5.20260712.1"
      },
      "react-ui": {
        "@base-ui/react": "1.6.0",
        "lucide-react": "1.24.0",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "shadcn": "4.13.0"
      },
      "styling": {
        "@tailwindcss/vite": "4.3.2",
        "class-variance-authority": "0.7.1",
        "clsx": "2.1.1",
        "tailwind-merge": "3.6.0",
        "tailwindcss": "4.3.2",
        "tw-animate-css": "1.4.0"
      },
      "tanstack": {
        "@tanstack/react-router": "1.170.17",
        "@tanstack/react-router-ssr-query": "1.167.1",
        "@tanstack/react-start": "1.168.27",
        "@tanstack/router-plugin": "1.168.19"
      },
      "types": {
        "@types/bun": "1.3.14",
        "@types/node": "26.1.1",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3"
      }
    }
  },
  "type": "module",
  "scripts": {
    "check:catalog": "vp exec bun scripts/check-catalog-usage.ts",
    "check:global": "vp run --filter @jfa.dev/landing --filter @jfa.dev/redirects --filter @jfa.dev/og-img-gen check",
    "check:outdated": "vp exec bun scripts/check-outdated-catalog.ts",
    "format": "vp fmt",
    "format:global": "vp run --filter @jfa.dev/landing --filter @jfa.dev/redirects --filter @jfa.dev/og-img-gen format"
  },
  "dependencies": {
    "jsdom": "29.1.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/jsdom": "28.0.3",
    "@types/node": "26.1.1",
    "oxfmt": "0.58.0",
    "typescript": "7.0.2",
    "vite-plus": "0.2.4"
  },
  "packageManager": "bun@1.4.0"
}
