{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "endOfLine": "lf",
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "insertFinalNewline": true,
  "sortPackageJson": {
    "sortScripts": true
  },
  "sortImports": {
    "order": "asc",
    "newlinesBetween": true,
    "internalPattern": ["@/"],
    "sortSideEffects": false,
    "groups": [
      "side_effect",
      "builtin",
      "internal",
      "parent",
      "sibling",
      "index",
      "unknown"
    ]
  },
  "sortTailwindcss": {
    "stylesheet": "./src/styles/globals.css",
    "functions": ["clsx", "cn", "cva", "twMerge"],
    "preserveDuplicates": false,
    "preserveWhitespace": false
  },
  "ignorePatterns": [
    "cloudflare-env.d.ts",
    "worker-configuration.d.ts",
    "src/routeTree.gen.ts",
    ".wrangler/**",
    "node_modules/**"
  ]
}
